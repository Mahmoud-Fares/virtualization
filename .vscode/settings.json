{
   "editor.formatOnSave": true,
   "editor.codeActionsOnSave": {
      "source.fixAll": "always",
      "source.organizeImports": "always"
   },
   "files.associations": {
      "*.css": "tailwindcss"
   },
   "tailwindCSS.lint.suggestCanonicalClasses": "ignore",
   "typescript.tsdk": "node_modules/typescript/lib"
}
